{
  "name": "kickstart-react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b --noEmit",
    "build": "npm run typecheck && vite build",
    "lint": "eslint ./src",
    "fmt": "dprint fmt",
    "fmt:check": "dprint check",
    "model:generate": "npx tsx ./scripts/generateModel.ts",
    "model:import": "npx tsx ./scripts/importProject.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.16.2",
    "@kontent-ai/delivery-sdk": "^16.4.3",
    "@kontent-ai/rich-text-resolver": "^2.0.4",
    "@portabletext/react": "^6.2.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query": "^5.100.11",
    "dotenv": "^17.4.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-error-boundary": "^6.1.1",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@kontent-ai/data-ops": "^2.6.2",
    "@kontent-ai/model-generator": "^10.0.1",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "dprint": "^0.54.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.6.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13"
  }
}
